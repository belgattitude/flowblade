{
  "name": "@flowblade/sqlduck",
  "version": "0.14.0",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./zod": {
      "types": "./dist/validation/zod/index.d.mts",
      "default": "./dist/validation/zod/index.mjs"
    },
    "./valibot": {
      "types": "./dist/validation/valibot/index.d.mts",
      "default": "./dist/validation/valibot/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "author": {
    "name": "Vanvelthem Sébastien",
    "url": "https://github.com/belgattitude"
  },
  "license": "MIT",
  "homepage": "https://github.com/belgattitude/flowblade",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/belgattitude/flowblade.git",
    "directory": "packages/sqlduck"
  },
  "scripts": {
    "clean": "rimraf ./dist ./coverage ./tsconfig.tsbuildinfo",
    "build": "tsdown",
    "build-release": "yarn build && rimraf ./_release && yarn pack && mkdir ./_release && tar zxvf ./package.tgz --directory ./_release && rm ./package.tgz",
    "docgen": "run-s docgen-typedoc",
    "docgen-typedoc": "rimraf ./docs/api && typedoc --plugin typedoc-plugin-markdown --out ./docs/api",
    "bench": "vitest bench --run",
    "bench-bun": "bun --bun run vitest bench --run",
    "bench-mitata": "node --experimental-strip-types --expose-gc bench/run_mitata.ts",
    "bench-mitata-bun": "bun --expose-gc bench/run_mitata.ts",
    "bench-codspeed": "cross-env CODSPEED=1 vitest bench --run",
    "bench-watch": "vitest bench",
    "test": "vitest run",
    "test-unit": "vitest run",
    "test-unit-bun": "bun --bun run vitest run",
    "test-unit-watch": "vitest --ui",
    "test-e2e": "vitest -c vitest.e2e.config.ts run",
    "test-e2e-bun": "bun --bun run vitest -c vitest.e2e.config.ts run",
    "test-e2e-watch": "vitest -c vitest.e2e.config.ts --ui",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../../.cache/eslint/sqlduck.eslintcache",
    "fix-staged": "lint-staged --allow-empty",
    "check-dist": "es-check --config=.escheckrc.json",
    "check-pub": "publint",
    "check-size": "size-limit"
  },
  "dependencies": {
    "@flowblade/core": "workspace:^",
    "@flowblade/source-duckdb": "workspace:^",
    "@flowblade/sql-tag": "workspace:^",
    "@httpx/assert": "^0.16.9",
    "@httpx/dsn-parser": "^1.9.9",
    "@httpx/plain-object": "^2.1.8",
    "@logtape/logtape": "^2.0.5",
    "@standard-schema/spec": "^1.1.0",
    "is-safe-filename": "0.1.1",
    "p-queue": "9.1.1",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@duckdb/node-api": "^1.5.0-r.1",
    "valibot": "^1.3.1"
  },
  "peerDependenciesMeta": {
    "valibot": {
      "optional": true
    }
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "8.12.0",
    "@dotenvx/dotenvx": "1.59.1",
    "@duckdb/node-api": "1.5.1-r.1",
    "@faker-js/faker": "10.4.0",
    "@flowblade/source-kysely": "workspace:^",
    "@httpx/assert": "0.16.9",
    "@mitata/counters": "0.0.8",
    "@size-limit/esbuild": "12.0.1",
    "@size-limit/file": "12.0.1",
    "@testcontainers/mssqlserver": "11.13.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@types/node": "25.5.2",
    "@typescript-eslint/eslint-plugin": "8.58.1",
    "@typescript-eslint/parser": "8.58.1",
    "@typescript/native-preview": "catalog:",
    "@vitest/coverage-v8": "4.1.3",
    "@vitest/ui": "4.1.3",
    "ansis": "4.2.0",
    "browserslist-to-esbuild": "2.1.1",
    "core-js": "3.49.0",
    "cross-env": "10.1.0",
    "es-check": "9.6.4",
    "es-toolkit": "1.45.1",
    "esbuild": "0.28.0",
    "eslint": "8.57.1",
    "execa": "9.6.1",
    "is-in-ci": "2.0.0",
    "kysely": "0.28.15",
    "mitata": "1.0.34",
    "npm-run-all2": "8.0.4",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "regexp.escape": "2.0.1",
    "rimraf": "6.1.3",
    "size-limit": "12.0.1",
    "sql-formatter": "15.7.3",
    "tarn": "3.0.2",
    "tedious": "19.2.1",
    "testcontainers": "11.13.0",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typedoc": "0.28.18",
    "typedoc-plugin-markdown": "4.11.0",
    "typescript": "6.0.2",
    "valibot": "1.3.1",
    "vitest": "4.1.3"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "directory": "_release/package"
  }
}
