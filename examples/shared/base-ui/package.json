{
  "name": "@examples/base-ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config.mjs": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "clean": "rimraf ./.next ./coverage ./tsconfig.tsbuildinfo",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest --ui",
    "bump-ui": "shadcn add --all --overwrite -c . && yarn lint --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../../.cache/eslint/base-ui.eslintcache",
    "fix-staged": "lint-staged --allow-empty",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.1.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "next-themes": "0.4.6",
    "react-day-picker": "9.14.0",
    "react-resizable-panels": "4.7.3",
    "recharts": "2.15.4",
    "sonner": "2.0.7",
    "tailwind-merge": "3.5.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "peerDependencies": {
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "8.10.0",
    "@storybook/addon-docs": "10.3.0",
    "@storybook/addon-vitest": "10.3.0",
    "@storybook/react-vite": "10.3.0",
    "@tailwindcss/postcss": "4.2.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "eslint": "8.57.1",
    "eslint-plugin-storybook": "10.2.19",
    "happy-dom": "20.8.4",
    "lucide-react": "0.577.0",
    "playwright": "1.58.2",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.3",
    "shadcn": "4.0.8",
    "storybook": "10.3.0",
    "tailwindcss": "4.2.1",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
