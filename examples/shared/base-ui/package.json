{
  "name": "@examples/base-ui",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    "./globals.css": "./src/styles/globals.css",
    "./postcss.config.mjs": "./postcss.config.mjs",
    "./lib/*": "./src/lib/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "clean": "rimraf ./.next ./coverage ./tsconfig.tsbuildinfo",
    "typecheck": "tsgo --project tsconfig.json --noEmit",
    "test": "vitest run",
    "test-unit": "vitest run",
    "test-unit-watch": "vitest --ui",
    "bump-ui": "shadcn add --all --overwrite -c . && yarn lint --fix",
    "bump-ux": "shadcn add sidebar-07 -o && yarn lint --fix",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx,.mjs,.cjs,.mts,.cts --cache --cache-location ../../../.cache/eslint/base-ui.eslintcache",
    "fix-staged": "lint-staged --allow-empty",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@shadcn/react": "0.2.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "next-themes": "0.4.6",
    "react-day-picker": "10.0.1",
    "react-resizable-panels": "4.11.2",
    "recharts": "3.8.0",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2"
  },
  "peerDependencies": {
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@belgattitude/eslint-config-bases": "8.16.0",
    "@storybook/addon-docs": "10.4.6",
    "@storybook/addon-vitest": "10.4.6",
    "@storybook/react-vite": "10.4.6",
    "@tailwindcss/postcss": "4.3.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.0.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.62.1",
    "@typescript-eslint/parser": "8.62.1",
    "@typescript/native-preview": "catalog:",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/browser": "4.1.9",
    "@vitest/coverage-v8": "4.1.9",
    "@vitest/ui": "4.1.9",
    "eslint": "8.57.1",
    "eslint-plugin-storybook": "10.4.6",
    "happy-dom": "20.10.6",
    "lucide-react": "1.21.0",
    "nock": "15.0.0-beta.12",
    "playwright": "1.61.1",
    "prettier": "3.9.4",
    "react": "19.2.7",
    "react-doctor": "0.5.8",
    "react-dom": "19.2.7",
    "rimraf": "6.1.3",
    "shadcn": "4.12.0",
    "storybook": "10.4.6",
    "tailwindcss": "4.3.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
