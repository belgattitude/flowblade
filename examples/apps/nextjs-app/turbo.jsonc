{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "env": ["NEXT_BUILD_*", "NEXT_PUBLIC_*", "SENTRY_*"],
      "outputs": [".next/**", "!.next/cache/**"],
      // We rely on tsconfig path aliases to ease starting
      "dependsOn": []
    },
    "typecheck": {},
    "dev": {
      "cache": false,
      "persistent": true
      //"dependsOn": ["^codegen"]
    }
  }
}
